<%- include('headerafterlogin'); -%>

  <div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body d-flex justify-content-between align-items-center">
        <h4 class="mb-0 fw-bold text-primary">QUẢN LÝ NHÀ TRỌ</h4>
        <button class="btn btn-primary" onclick="$('#addRoomModal').modal('show')">
          <i class="bi bi-plus-circle"></i> Thêm phòng mới
        </button>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Tên Phòng</th>
              <th>Giá Thuê</th>
              <th>Số Điện (Cũ -> Mới)</th>
              <th>Số Nước (Cũ -> Mới)</th>
              <th class="text-center">Thao tác</th>
            </tr>
          </thead>
          <tbody id="roomTable">
          </tbody>
        </table>
      </div>
    </div>
    <div class="card shadow-sm border-0 mt-5">
      <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-secondary"><i class="bi bi-clock-history"></i> LỊCH SỬ XUẤT HÓA ĐƠN</h5>
      </div>
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Ngày in</th>
              <th>Phòng</th>
              <th>Chi tiết số (Điện | Nước)</th>
              <th>Tổng tiền</th>
              <th class="text-center">Thao tác</th>
            </tr>
          </thead>
          <tbody id="historyTable">
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="modal fade" id="addRoomModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content border-0 shadow">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title">Cấu hình phòng mới</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4">
          <label class="small fw-bold">Tên phòng</label>
          <input type="text" id="add_name" class="form-control mb-3" placeholder="Ví dụ: P.101">

          <label class="small fw-bold">Giá thuê cố định (đ)</label>
          <input type="number" id="add_price" class="form-control mb-3" placeholder="2,500,000">

          <div class="row">
            <div class="col">
              <label class="small fw-bold">Số điện cũ</label>
              <input type="number" id="add_elec" class="form-control" placeholder="Chỉ số hiện tại">
            </div>
            <div class="col">
              <label class="small fw-bold">Số nước cũ</label>
              <input type="number" id="add_water" class="form-control" placeholder="Chỉ số hiện tại">
            </div>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
          <button class="btn btn-primary" onclick="submitAddRoom()">Xác nhận thêm</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const PRICE_DIEN = 3100;
    const PRICE_NUOC = 10000;

    async function loadRooms() {
      const res = await fetch('/api/rooms');
      const rooms = await res.json();
      let html = '';

      rooms.forEach(r => {
        html += `
        <tr>
            <td class="fw-bold text-dark">${r.room_name}</td>
            <td class="text-success fw-bold">${Number(r.base_price).toLocaleString()}đ</td>
            <td>
                <span class="text-muted small">Cũ: ${r.current_elec}</span>
                <input type="number" id="new_elec_${r.id}" class="form-control form-control-sm mt-1" style="width:100px" placeholder="Số mới">
            </td>
            <td>
                <span class="text-muted small">Cũ: ${r.current_water}</span>
                <input type="number" id="new_water_${r.id}" class="form-control form-control-sm mt-1" style="width:100px" placeholder="Số mới">
            </td>
            <td class="text-center">
                <button class="btn btn-sm btn-success px-3" onclick='calculateAndPrint(${JSON.stringify(r)})'>Tính & In</button>
                <button class="btn btn-sm btn-outline-danger" onclick="deleteRoom(${r.id})">Xóa</button>
            </td>
        </tr>`;
      });
      $('#roomTable').html(html);
    }

    function calculateAndPrint(room) {
      const nElec = document.getElementById(`new_elec_${room.id}`).value;
      const nWater = document.getElementById(`new_water_${room.id}`).value;

      if (!nElec || !nWater) return alert("Chưa nhập số điện/nước mới!");

      const sDien = parseInt(nElec) - parseInt(room.current_elec);
      const sNuoc = parseInt(nWater) - parseInt(room.current_water);

      if (sDien < 0 || sNuoc < 0) return alert("Lỗi: Số mới đang nhỏ hơn số cũ!");

      const tienDien = sDien * PRICE_DIEN;
      const tienNuoc = sNuoc * PRICE_NUOC;
      const tienRac = 25000;
      const tong = Number(room.base_price) + tienDien + tienNuoc + tienRac;

      const qrUrl = `https://img.vietqr.io/image/VCB-1065378555-qr_only.png?amount=${tong}&addInfo=${room.room_name.replace(/\s/g, '%20')}`;

      const invoiceContent = `
        <html>
        <head>
            <title>HÓA ĐƠN TIỀN TRỌ: ${room.room_name}</title>
            <style>
                @page { 
                    size: 150mm 100mm; 
                    margin: 0; 
                }
                body { 
                    font-family: 'Tahoma', sans-serif;
                    width: 150mm;
                    height: 100mm;
                    margin: 0;
                    padding: 5mm 8mm; /* Giảm padding dọc */
                    box-sizing: border-box;
                    overflow: hidden; /* Ngăn tràn trang */
                    color: #000;
                }
                .header-title {
                    font-size: 26px;
                    font-weight: bold;
                    text-transform: uppercase;
                    border-bottom: 2px solid #000;
                    text-align: center;
                    margin-bottom: 8px;
                }
                .main-container {
                    display: flex;
                    justify-content: space-between;
                    height: 70mm; /* Ép độ cao vùng nội dung */
                }
                .left-col {
                    width: 65%;
                    border-right: 1px dashed #000;
                    padding-right: 5mm;
                }
                .right-col {
                    width: 30%;
                    text-align: center;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                }
                .info-row {
                    display: flex;
                    justify-content: space-between;
                    margin: 4px 0;
                    font-size: 25px;
                }
                .calc-text {
                    font-size: 16px;
                    color: #444;
                    margin-top: -2px;
                    margin-bottom: 5px;
                }
                .total-row {
                    margin-top: 20px;
                    padding-top: 5px;
                    border-top: 2px solid #000;
                    display: flex;
                    justify-content: space-between;
                    font-size: 26px;
                    font-weight: bold;
                }
                .qr-code {
                    width: 150px;
                    height: 150px;
                }
                .footer-note {
                    font-size: 13px;
                    text-align: center;
                    border-top: 1px solid #000;
                    margin-top: 5px;
                    padding-top: 3px;
                    font-weight: bold;
                }
                b { font-weight: bold; }
            </style>
        </head>
        <body>
            <div class="header-title">HÓA ĐƠN TIỀN TRỌ: ${room.room_name}</div>
            
            <div class="main-container">
                <div class="left-col">
                    <div class="info-row"><span>Tiền phòng:</span> <b>${Number(room.base_price).toLocaleString()}đ</b></div>
                    
                    <div style="margin: 5px 0;">
                        <div class="info-row"><span>Tiền điện:</span> <b>${tienDien.toLocaleString()}đ</b></div>
                        <div class="calc-text">(${room.current_elec} → ${nElec}) = ${sDien} số</div>
                    </div>

                    <div style="margin: 5px 0;">
                        <div class="info-row"><span>Tiền nước:</span> <b>${tienNuoc.toLocaleString()}đ</b></div>
                        <div class="calc-text">(${room.current_water} → ${nWater}) = ${sNuoc} khối</div>
                    </div>

                    <div class="info-row" style="margin-top:10px"><span>Tiền rác:</span> <b>${tienRac.toLocaleString()}đ</b></div>
                    
                    <div class="total-row">
                        <span>TỔNG CỘNG:</span> 
                        <span>${tong.toLocaleString()}đ</span>
                    </div>
                </div>

                <div class="right-col">
                    <div style="font-size: 14px; font-weight: bold; margin-bottom: 5px;">QUÉT THANH TOÁN</div>
                    <img src="${qrUrl}" class="qr-code">
                    <div style="font-size: 13px; margin-top: 5px; line-height: 1.2;">
                        <b>VCB - 1065378555</b><br>
                        HO KINH DOANH BAO BOI
                    </div>
                </div>
            </div>

            <div class="footer-note">
                THANH TOÁN TRƯỚC NGÀY 15. XIN CẢM ƠN!
            </div>

            <script>
                window.onload = function() {
                    setTimeout(function() {
                        window.print();
                    }, 800);
                };
                window.onafterprint = function() {
                    window.close();
                };
            <\/script>
        </body>
        </html>
    `;

      const pW = window.open('', '_blank');
      pW.document.open();
      pW.document.write(invoiceContent);
      pW.document.close();

      setTimeout(() => {
        if (confirm(`Đã in hóa đơn ${room.room_name}. Chốt số điện nước và lưu lịch sử không?`)) {
          fetch('/api/rooms/update-stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: room.id, new_elec: nElec, new_water: nWater })
          });

          const historyData = {
            room_id: room.id,
            room_name: room.room_name,
            details: `Điện: ${room.current_elec}->${nElec} (${sDien} số); Nước: ${room.current_water}->${nWater} (${sNuoc} khối)`,
            total_amount: tong
          };

          fetch('/api/invoices/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(historyData)
          }).then(() => {
            loadRooms();
            loadHistory();
          });
        }
      }, 2000);
    }
    async function loadHistory() {
      const res = await fetch('/api/invoices');
      const history = await res.json();
      let html = '';
      history.forEach(h => {
        html += `
    <tr>
      <td class="small">${new Date(h.created_at).toLocaleDateString('vi-VN')}</td>
      <td class="fw-bold">${h.room_name}</td>
      <td class="small text-muted">${h.details}</td>
      <td class="text-danger fw-bold">${Number(h.total_amount).toLocaleString()}đ</td>
      <td class="text-center">
        <button class="btn btn-sm btn-outline-secondary" onclick="deleteInvoice(${h.id})">Xóa</button>
      </td>
    </tr>`;
      });
      $('#historyTable').html(html);
    }
    async function submitAddRoom() {
      const data = {
        room_name: $('#add_name').val(),
        base_price: $('#add_price').val(),
        current_elec: $('#add_elec').val(),
        current_water: $('#add_water').val()
      };
      if (!data.room_name || !data.base_price) return alert("Nhập thiếu tên hoặc giá phòng kìa ông!");

      await fetch('/api/rooms/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      $('#addRoomModal').modal('hide');
      loadRooms();
    }

    async function deleteRoom(id) {
      if (!confirm("Xóa phòng này là mất sạch dữ liệu đó, chắc chưa?")) return;
      await fetch('/api/rooms/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
      });
      loadRooms();
    }
    async function deleteInvoice(id) {
      if (!confirm("Ông chắc chắn muốn xóa lịch sử hóa đơn này không? Xóa là mất luôn đó!")) return;

      try {
        const res = await fetch('/api/invoices/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id })
        });

        const result = await res.json();

        if (result.success) {
          // Load lại bảng lịch sử sau khi xóa thành công
          loadHistory();
        } else {
          alert("Có lỗi xảy ra khi xóa: " + result.error);
        }
      } catch (err) {
        console.error("Lỗi kết nối API:", err);
        alert("Không thể kết nối đến server!");
      }
    }

    // Chạy khi load trang
    loadRooms();
    loadHistory();
  </script>

  <%- include('footer'); -%>