<%- include('header'); -%>
<section class="h-100">
		<div class="container h-100">
			<div class="row justify-content-sm-center h-100">
				<div class="col-xxl-4 col-xl-5 col-lg-5 col-md-7 col-sm-9">
					<div class="text-center my-5">
						<img src="images/logo.png" alt="logo" width="100">
					</div>
					<div class="card shadow-lg">
						<div class="card-body p-5">
							<center><h1 class="text2">Áo Dài Gia Bảo</h1></center>
                            <div>
                                <% if(errors != "") { %>
                                    <% errors.forEach((item) => { %>
                                        <div class="alert alert-danger">
                                            <%- item %>
                                        </div>
                                    <% }); %>
                                <% } %>
                            </div>
							<form method="POST" novalidate="" autocomplete="off" action="/login">
								<div class="mb-3">
									<input id="username" placeholder="User ADGB" type="username" class="form-control" name="username" value="" required autofocus>
								</div>

								<div class="mb-3">
									<input id="password" placeholder="Password" type="password" class="form-control" name="password" required>
								</div>

								<div class="d-flex align-items-center">
									<button type="submit" class="btn btn-primary ms-auto">
										Đăng nhập
									</button>
								</div>
							</form>
						</div>
						<div class="card-footer py-3 border-0">
							<div class="text-center text">
								Copyright © 2022 Áo Dài Gia Bảo
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

<%- include('footer'); -%>