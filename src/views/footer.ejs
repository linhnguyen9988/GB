  function makeid(length) {
    var result = '';
    var characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    var charactersLength = characters.length;
    for (var i = 0; i < length; i++) {
      result += characters.charAt(Math.floor(Math.random() *
        charactersLength));
    }
    return result;
  }
  function Notify(image, name, time, message) {
    var id = makeid(10);
    document.getElementById("notix").insertAdjacentHTML("afterend",
      `<div id="` + id + `" class="toast hide toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="3000">
                <div class="toast-header">
                    <img src='`+ image + `' class="rounded me-2" alt="..." width="30px" height="30px">
                    <strong class="me-auto">`+ name + `</strong>
                    <small class="text-muted">`+ time + `</small>
                    <button type="button" class="btn-close" data-bs-dismiss="toast"
                        aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    `+ message + `
                </div>
            </div>`);
    $('.toast').toast('show');
    $('.toast').on('hidden.bs.toast', function () {
      var div = document.getElementById(id);
      div.remove();
    });
  }
