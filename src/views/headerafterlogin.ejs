  async function PrintFromMess(id, name, phone, url, text, diachi, nuocngoai) {
    let giaValue = document.getElementById("gia").value;

    var printData = {
      date: ToDay(),
      name: name.replace(/<[^>]*>?/gm, '').trim(),
      phone: phone ? phone.replace(/<[^>]*>?/gm, '').trim() : "",
      comment: text,
      gia: giaValue ? giaValue.toString().replace(/[^0-9]/g, "") : "0",
      id: id,
      avabase64: url.startsWith('http') ? url : window.location.origin + url,
      address: diachi,
      region: nuocngoai
    };

    try {
      const resPdf = await fetch('/api/generate-pdf', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(printData)
      }).then(r => r.json());

      if (resPdf.success) {
        fetch('/print-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            userId: window.CURRENT_USER_ID,
            type: 'pdf',
            content: resPdf.pdfBase64,
            config: {
              printerName: "XP-80C",
              widthMm: 80,
              heightMm: 100,
              marginTopPx: 0
            }
          })
        })
          .then(r => r.json())
          .then(res => {
            if (res.success) {
            } else {
              alert("Máy in đang Offline!");
            }
          });
      } else {
        alert("Lỗi khi tạo file in trên Server!");
      }
    } catch (err) {
      console.error("Lỗi hệ thống in:", err);
    }
  }

  function tryAgain(e, maxRetries = 5, retryInterval = 1000) {
    let retries = 0;
    const checkAndReload = () => {
      if (retries >= maxRetries) {
        return;
      }
      const source = e.src;
      const url = source.split('?')[0];
      const newSrc = url + '?timestamp=' + new Date().getTime();

      const newImg = new Image();

      newImg.onload = function () {
        e.src = newImg.src;
      };
      newImg.onerror = function () {
        retries++;
        setTimeout(checkAndReload, retryInterval);
      };
      newImg.src = newSrc;
    };
    checkAndReload();
  }

