  function OrderJourney(orderNumber, customerName, userId, customerPhone) {
    if (!orderNumber || orderNumber === 'undefined') {
      alert("Mã vận đơn không hợp lệ!");
      return;
    }

    document.getElementById('header-order-number').innerText = orderNumber;
    document.getElementById('header-customer-name').innerText = customerName || 'Khách hàng';

    const avatarImg = document.getElementById('header-customer-avatar');
    avatarImg.src = userId ? `/images/ava/${userId}.jpg` : '/images/ava/default.jpg';

    document.getElementById('header-customer-phone').innerText = customerPhone || '---';
    const phoneLink = document.getElementById('header-customer-phone-link');
    if (customerPhone) {
      phoneLink.href = `tel:${customerPhone}`;
      phoneLink.style.pointerEvents = "auto";
    } else {
      phoneLink.href = "#";
      phoneLink.style.pointerEvents = "none";
    }

    $('#trackingModal').modal('show');

    const content = document.getElementById('modal-tracking-content');
    content.innerHTML = '<div class="text-center p-4"><i class="fa fa-spinner fa-spin"></i> Đang tải hành trình...</div>';

    fetch(`/api/orders/logs/${orderNumber}`)
      .then(response => {
        if (!response.ok) throw new Error('Không thể kết nối API');
        return response.json();
      })
      .then(res => {
        const logs = Array.isArray(res) ? res : (res.data || []);
        if (logs.length > 0) {
          let html = '';
          logs.forEach((log) => {
            const formattedCOD = new Intl.NumberFormat('vi-VN').format(log.money_collection || 0) + ' ₫';
            const phone = log.employee_phone || '';

            html += `
                    <div class="tracking-card">
                        <span class="card-status">${log.status_name}</span>
                        - <span class="card-time">${log.status_date_raw || ''}</span>
                        <div class="card-location">📍 ${log.location || 'Đang cập nhật...'}</div>
                        ${log.employee_name ? `<a href="tel:${phone}" class="shipper-tag"><b>${log.employee_name}</b>&nbsp;${phone ? '- ' + phone : ''}</a>` : ''}
                        <div style="font-size: 0.8rem; color: #28a745; margin-top: 5px; font-weight: 600;">💰 COD: ${formattedCOD}</div>
                        ${log.note ? `<div class="text-muted mt-1" style="font-size:0.8rem">📝 ${log.note}</div>` : ''}
                    </div>`;
          });
          content.innerHTML = html;
        } else {
          content.innerHTML = `
                    <div class="text-center p-4">
                        <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" style="width: 80px; opacity: 0.5">
                        <p class="mt-3 text-muted">Đơn hàng này chưa có hành trình chi tiết.</p>
                    </div>`;
        }
      })
      .catch(err => {
        content.innerHTML = `<div class="alert alert-danger">Lỗi: ${err.message}</div>`;
      });
  }

