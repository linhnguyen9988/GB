  // -- Song song 18 goc (0..170 buoc 10), lay ket qua nhanh nhat --
  // Da bo co che xoay 18 goc/150ms (tao qua nhieu canvas -> crash Safari iOS).
  // Gio chi dung 1 engine quet duy nhat, tang toc do quet (maxScansPerSecond)
  // de van nhay nhung khong tao canvas thua.
  var _rotLast = '';
  var _rotCool = false;

  // Giu lai 2 ham rong de cac cho goi _startRot()/_stopRot() khong loi.
  function _startRot() { }
  function _stopRot() { }

  const scanner = new QrScanner(video, function (result) {
    if (!_rotCool && result.data !== _rotLast) {
      _rotLast = result.data;
      _rotCool = true;
      setTimeout(function () { _rotCool = false; _rotLast = ''; }, 300);
      setResult(result);
    }
  }, {
    onDecodeError: function () { },
    highlightScanRegion: true,
    highlightCodeOutline: true,
    maxScansPerSecond: 15, // quet nhanh hon de bat nhay, khong tao canvas phu
    calculateScanRegion: function (v) {
      return {
        x: 0, y: 0,
        width: v.videoWidth || 640,
        height: v.videoHeight || 480,
        downScaledWidth: Math.min(v.videoWidth || 640, 640),
        downScaledHeight: Math.min(v.videoHeight || 480, 480),
      };
    },
  });
  QrScanner.listCameras(true).then(cameras => cameras.forEach(camera => {
    const option = document.createElement('option');
    option.value = camera.id;
    option.text = camera.label;
    camList.add(option);
    if (option.text == 'Back Ultra Wide Camera' || option.text == 'Camera cực rộng mặt sau') {//3 camera lay 
      option.selected = true;
      scanner.setCamera(option.value)
    }
  }));
  // for debugging
  window.scanner = scanner;
  //document.getElementById('scanstyle').addEventListener('change', (e) => {
  //  videoContainer.className = e.target.value;
  //  scanner._updateOverlay(); // reposition the highlight because style 2 sets position: relative
  //});

  camList.addEventListener('change', event => {
    scanner.setCamera(event.target.value);
  });

  document.getElementById('start-button').addEventListener('click', () => {
    document.getElementById("video-container").style.display = "block";
    scanner.start().then(function () { _startRot(); });
  });

  //document.getElementById('stop-button').addEventListener('click', () => {
  //  scanner.stop();
  //});
</script>
