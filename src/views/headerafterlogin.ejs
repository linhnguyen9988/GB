  function MakeQRCode(data, style) {
    var qr = qrcode(0, 'H');//LMQH
    qr.addData(data, style);//test style = byte
    qr.make();
    return qr.createImgTag(3);
  }
  function ToDay() {
    var today = new Date();
    var dd = String(today.getDate()).padStart(2, '0');
    var mm = String(today.getMonth() + 1).padStart(2, '0');
    var yyyy = today.getFullYear().toString().slice(2);
    var hours = today.getHours();
    var ampm = '';
    if (hours > 2 && hours < 19) {
      ampm = 'S';
    } else {
      ampm = 'T';
    }
    return dd + '/' + mm + '/' + yyyy + ' • ' + ampm;
  }

