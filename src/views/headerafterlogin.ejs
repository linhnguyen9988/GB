  function titleCase(str) {
    var splitStr = str.toLowerCase().split(' ');
    for (var i = 0; i < splitStr.length; i++) {
      splitStr[i] = splitStr[i].charAt(0).toUpperCase() + splitStr[i].substring(1);
    }
    return splitStr.join(' ');
  }
  function FillDiaChiLenDon(phone) {
    $.ajax({
      url: "/getdiachilendon",
      method: "POST",
      data: { phone: phone, userid: userid },
      dataType: "JSON",
      success: function (data) {
        const select = document.getElementById('diachilendonviettel');

        for (var i = 0; i < data.data.length; i++) {
          var item = data.data[i];
          var opt = document.createElement('option');
          opt.value = item.id;
          opt.text = (item.jtready ? '✅ ' : '⚠️ ') + item.address;
          opt.dataset.xa = item.xa || '';
          opt.dataset.huyen = item.huyen || '';
          opt.dataset.tinh = item.tinh || '';
          opt.dataset.xajt = item.xajt || '';
          opt.dataset.huyenjt = item.huyenjt || '';
          opt.dataset.tinhjt = item.tinhjt || '';
          opt.dataset.address = item.address || '';
          opt.dataset.jtready = item.jtready ? '1' : '0';
          opt.dataset.dbid = item.id;
          select.appendChild(opt);
        }

        const autoCheck = (opt) => {
          if (opt && opt.dataset.jtready === '0' && !opt.disabled) {
            AutoValidateJT(opt);
          }
        };

        if (select.options.length > 0) {
          autoCheck(select.options[select.selectedIndex || 0]);
        }

        select.onchange = function () {
          autoCheck(this.options[this.selectedIndex]);
        };
      }
    });
  }

  async function AutoValidateJT(opt) {
    var address = opt.dataset.address;
    var phoneEl = document.getElementById('phoneviettel') || document.getElementById('userphone');
    var phone = phoneEl ? phoneEl.value : '';

    if (!address || address.length < 5) return;

    var oldText = opt.text;
    opt.text = '🔄 ' + address;
    opt.disabled = true;

    try {
      const res = await fetch('/checkaddress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          phone: phone,
          diachi: address,
          name: window.fbnamex || '',
          khid: window.khid || '',
          userid: window.userid || ''
        })
      });
      const data = await res.json();

      // HIỆN SNACKBAR ADX NGAY
      if (data.adx) {
        ShowToast('info', '<i class="bi bi-geo-alt-fill"></i>', 'Viettel chuẩn hóa', data.adx, 4000);
      }

      if (data.error) {
        opt.text = '❌ ' + address;
        opt.disabled = false;
        ShowToast('danger', '<i class="bi bi-exclamation-triangle"></i>', 'Lỗi địa chỉ', data.error, 4000);
        return;
      }

      if (data.jtready && data.xajt) {
        opt.dataset.xajt = data.xajt || '';
        opt.dataset.huyenjt = data.huyenjt || '';
        opt.dataset.tinhjt = data.tinhjt || '';
        opt.dataset.xa = data.adx.split(',')[0]?.trim() || '';
        opt.dataset.huyen = data.adx.split(',')[1]?.trim() || '';
        opt.dataset.tinh = data.adx.split(',')[2]?.trim() || '';
        opt.dataset.jtready = '1';
        opt.text = '✅ ' + address;
      } else {
        opt.text = '⚠️ ' + address;
        ShowToast('warning', '<i class="bi bi-truck"></i>', 'J&T', data.jtError || 'Chưa có dữ liệu J&T', 4000);
      }
      opt.disabled = false;
    } catch (e) {
      opt.text = oldText;
      opt.disabled = false;
      ShowToast('danger', '<i class="bi bi-wifi-off"></i>', 'Lỗi mạng', e.message, 4000);
    }
  }

  function removeOptions(selectElement) {
    var i, L = selectElement.options.length - 1;
    for (i = L; i >= 0; i--) {
      selectElement.remove(i);
    }
  }
  function ThemDiaChi(userid) {
    var diachi = titleCase(document.getElementById("diachiviettel").value.trim());
    var phone = document.getElementById("phoneviettel").value.trim();

    if (phone.length !== 10 && !(phone.length === 11 && phone.startsWith("02"))) {
      alert('Sai số điện thoại, kiểm tra lại');
      return;
    }
    if (diachi.length < 10) {
      alert('Địa chỉ phải trên 10 ký tự');
      return;
    }

    $.ajax({
      url: "/checkaddress",
      method: "POST",
      data: { name: fbnamex, phone: phone, diachi: diachi, khid: khid, userid: userid },
      dataType: "JSON",
      success: function (data) {
        if (data.hasOwnProperty('error')) {
          alert(data.error);
          return;
        }

        const select = document.getElementById('diachilendonviettel');

        [...select.options].forEach(opt => {
          if (opt.dataset.address === diachi) opt.remove();
        });

        const adxParts = (data.adx || '').split(',').map(s => s.trim());
        const xa = adxParts[0] || '';
        const huyen = adxParts[1] || '';
        const tinh = adxParts[2] || '';

        const opt = document.createElement('option');
        opt.value = data.id || diachi;
        opt.text = (data.jtready ? '✅ ' : '⚠️ ') + diachi;

        opt.dataset.address = diachi;
        opt.dataset.xa = xa;
        opt.dataset.huyen = huyen;
        opt.dataset.tinh = tinh;
        opt.dataset.xajt = data.xajt || '';
        opt.dataset.huyenjt = data.huyenjt || '';
        opt.dataset.tinhjt = data.tinhjt || '';
        opt.dataset.jtready = data.jtready ? '1' : '0';
        opt.dataset.dbid = data.id || '';

        select.appendChild(opt);
        select.value = opt.value;

        alert(`GB: ${diachi}\nViettel: ${data.adx}`);
        UpdateAddress2(userid);
      }
    });
  }
</script>
