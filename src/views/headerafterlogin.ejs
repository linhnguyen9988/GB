  function copyOrderNumber(element) {
    const orderNumber = element.innerText.trim();
    const toast = document.getElementById('copy-toast');

    if (!orderNumber || orderNumber === '...') return;

    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(orderNumber).then(() => showSuccess(element, toast));
    } else {
      const textArea = document.createElement("textarea");
      textArea.value = orderNumber;
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        showSuccess(element, toast);
      } catch (err) {
        alert('Lỗi: Trình duyệt không hỗ trợ copy');
      }
      document.body.removeChild(textArea);
    }
  }

  function showSuccess(element, toast) {
    const originalColor = element.style.color;
    const originalBorder = element.style.borderColor;
    element.style.color = "#28a745";
    element.style.borderColor = "#28a745";

    setTimeout(() => {
      element.style.color = "";
      element.style.borderColor = "";
      element.style.fontWeight = "";
    }, 1500);
  }

