  async function convertImageToBase64() {
    let image = $('#attachimage')[0]['files']

    if (image && image[0]) {

      const reader = new FileReader();

      return new Promise(resolve => {
        reader.onload = ev => {
          resolve(ev.target.result)
        }
        reader.readAsDataURL(image[0])
      })
    }
  }
  var i64 = '';
  var waitx = 1;
  async function ResizeB64() {
    var canvas = document.createElement("canvas");
    var ctx = canvas.getContext("2d");
    var image = new Image();
    image.src = await convertImageToBase64();
    await document.getElementById("original").appendChild(image);

    image.onload = async function (e) {
      var x = 1;
      if (image.width > 3000 || image.height > 3000) {
        x = 2;
      }
      if (image.width > 5000 || image.height > 5000) {
        x = 4;
      }
      canvas.width = image.width / x;
      canvas.height = image.height / x;

      await ctx.drawImage(image,
        0, 0, image.width, image.height,
        0, 0, canvas.width, canvas.height
      );
      i64 = await canvas.toDataURL();
      waitx = 2;
    };
    $('#original').hide()
  }
  function WaitUntil(conditionFunction) {
    const poll = resolve => {
      if (conditionFunction()) resolve();
      else setTimeout(_ => poll(resolve), 100);
    }
    return new Promise(poll);
  }
  function makeid(length) {
    let result = '';
    const characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    const charactersLength = characters.length;
    let counter = 0;
    while (counter < length) {
      result += characters.charAt(Math.floor(Math.random() * charactersLength));
      counter += 1;
    }
    return result;
  }

