<%- include('headerafterlogin'); -%>
    <div id="notetoshow">
    </div>
    <div class="table-responsive">
        <div class="table-wrapper">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-2">
                            <form class="was-validated">
                                <div class="input-group mb-1">
                                    <span class="input-group-text">ID</span>
                                    <input type="text" id="liveidinput" class="form-control input-sm"
                                        placeholder="Nhập liveid vào" aria-label="LiveID"
                                        aria-describedby="basic-addon1" required>
                                    <!--<button type="button" class="btn btn-primary" id="scancomment"
                                    onclick="ScanComment()">Quét</button>-->
                                    <button type="button" class="btn btn-primary" id="begin"
                                        onclick="Begin()">Begin</button>
                                    <button type="button" class="btn btn-primary" id="begin"
                                        onclick="ScrollBot()">BOT</button>
                                        <button type="button" class="btn btn-primary" id="begin"
                                        onclick="ADS()">ADS</button>
                                </div>
                            </form>
                            <div class="d-none d-md-block">
                                <div class="input-group mb-3">
                                    <input type="text" id="livenote" class="form-control input-sm"
                                        onfocusout="OnUpdateLiveNote()" placeholder="Ghi chú live">
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="input-group mb-3">
                                <select id="liveidcombobox" class="form-select">
                                    <% if(data.length){ for(var i=0; i< data.length; i++) {%>
                                        <option value="<%= data[i].id%>" id="<%= data[i].id%>"
                                            data-note="<%= data[i].note%>">
                                            <%= data[i].name%> - <%= data[i].luotincuoi%>
                                        </option>
                                        <% } }else{ %>
                                            <option value="none" id="none">
                                                Chưa có live.
                                            </option>
                                            <% } %>
                                </select>
                                <button type="button" class="btn btn-primary" id="btnloadlive"
                                    onclick="LoadLive()">Load</button>
                                <!--<button type="button" class="btn btn-primary" id="btnloadlive"
                                onclick="DeleteLive()">Del</button>-->
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <table class="table table-striped table-responsive-xl" id="comment_table"
                style="width:100%;">
                <thead>
                    <tr>
                        <th style="width: 0;"></th>
                        <th style="width: 20%; white-space: normal;">Tên khách</th>
                        <th style="width: 80%;">Bình luận</th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                        <th style="width: 0;"></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
    <script src="/js/readcomment.js"></script>
    <%- include('footer'); -%>