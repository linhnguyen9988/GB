<%- include('headerafterlogin'); -%>
    <div id="notetoshow">
    </div>
    <div class="table-responsive">
        <div class="table-wrapper">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-2">
                            <form class="was-validated">
                                <div class="input-group mb-1">
                                    <span class="input-group-text">ID</span>
                                    <input type="text" id="liveidinput" class="form-control input-sm"
                                        placeholder="Nhập liveid vào" aria-label="LiveID"
                                        aria-describedby="basic-addon1" required>
                                    <!--<button type="button" class="btn btn-primary" id="scancomment"
                                    onclick="ScanComment()">Quét</button>-->
                                    <button type="button" class="btn btn-primary" id="begin"
                                        onclick="Begin()">Begin</button>
                                </div>
                            </form>
                            <div class="d-none d-md-block">
                                <div class="input-group mb-3">
                                    <input type="text" id="livenote" class="form-control input-sm"
                                        onfocusout="OnUpdateLiveNote()" placeholder="Ghi chú live">
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="input-group mb-1">
                                <select id="soluonglive" class="form-select">
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                    <option value="4">4</option>
                                    <option value="5">5</option>
                                </select>
                                <select id="liveidcombobox" class="form-select w-50">
                                    <% if(data.length){ for(var i=0; i< data.length; i++) {%>
                                        <option value="<%= data[i].id%>" id="<%= data[i].id%>"
                                            data-note="<%= data[i].note%>">
                                            <%= data[i].name%> - <%= data[i].luotincuoi%>
                                        </option>
                                        <% } }else{ %>
                                            <option value="none" id="none">
                                                Chưa có live.
                                            </option>
                                            <% } %>
                                </select>
                                <button type="button" class="btn btn-primary" id="btnloadlive"
                                    onclick="LoadLive()">Load</button>
                                <!--<button type="button" class="btn btn-primary" id="btnloadlive"
                                onclick="DeleteLive()">Del</button>-->
                            </div>
                            <!--<div class="d-none d-md-block">
                                <label for="holdToast">
                                    <input type="checkbox" id="holdToast">
                                    Giữ thông báo
                                </label>
                                <span id="referral"></span>
                            </div>-->
                            
                        </div>
                        <div class="col-sm-5 d-none d-md-block">
                            <div class="input-group mb-1">
                                <div class="col-1">
                                    <input type="text" pattern="[0-9]+" inputmode="numeric" id="slchot" value="1"
                                        class="form-control input-sm" width="20px" min="1" max="10"
                                        onfocus="SelectX(this)" onkeyup="onlyNumberAmount(this)">
                                </div>
                                <div class="col-2">
                                    <input type="text" pattern="[0-9]+" inputmode="numeric" id="gia"
                                        class="form-control input-sm" width="20px" min="0" max="50"
                                        onfocus="SelectX(this)" onkeyup="onlyNumberAmount(this)">
                                </div>

                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">50</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">55</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">60</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">70</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">79</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">80</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">89</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">90</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">100</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">110</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">120</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">130</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">140</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">150</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">160</button>
                                <button type="button" class="btn btn-outline-success"
                                    onclick="Chot(this.innerHTML)">170</button>
                                    <button type="button" class="btn btn-outline-success"
                                    onclick="Chot()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <table class="table table-striped table-responsive-xl" id="comment_table" style="width:100%">
                <thead>
                    <tr>
                        <th>#</th>
                        <th style="white-space:nowrap; width: 25%"><img src="/images/icon/woman.png"> Tên khách</th>
                        <th style="width: 40%"><img src="/images/icon/comment.png"> Bình luận</th>
                        <th></th>
                        <th></th>
                        <th style="width: 5%"><img src="/images/icon/checkedz.png"> Chốt</th>
                        <th style="width: 5%"><img src="/images/icon/money.png"> Giá</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th><!-- 10 -->
                        <th style="width: 10%"><img src="/images/icon/action.png"> Action</th>
                        <th></th>
                        <th style="width: 10%"><img src="/images/icon/timetable.png"> Time</th>
                        <th></th>
                        <th></th>
                        <th style="width: 5%"><img src="/images/icon/123.png"> Lượt in</th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    </div>
    <script src="/js/loadcomment.js"></script>
    <%- include('footer'); -%>